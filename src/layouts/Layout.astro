---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
}

const { title = 'Portfolio' } = Astro.props;
---

<!doctype html>
<html lang="id" class="h-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline>
			// Prevent flash of unstyled content
			const theme = localStorage.getItem('theme') || 'dark';
			if (theme === 'light') {
				document.documentElement.classList.add('light-mode');
			}
		</script>
	</head>
	<body class="h-full overflow-hidden transition-colors duration-300">
		<!-- Navbar -->
		<Navbar />

		<!-- Content Area dengan Rounded Corners -->
		<div id="main-content" class="h-full pt-20 md:pt-24 pb-12 md:pb-14 p-3 md:p-4 transition-all duration-300">
			<div class="content-container h-full backdrop-blur-md rounded-2xl md:rounded-3xl shadow-2xl overflow-hidden transition-all duration-300">
				<div class="h-full overflow-y-auto custom-scrollbar">
					<slot />
				</div>
			</div>
		</div>

		<!-- Right Sidebar (Border kanan yang melebar) -->
		<aside id="right-sidebar" class="fixed top-0 right-0 h-full sidebar-width pt-20 md:pt-24 pb-12 md:pb-14 pr-3 md:pr-4 transition-all duration-300 z-30">
			<div class="sidebar-content h-full backdrop-blur-md rounded-2xl md:rounded-3xl shadow-2xl overflow-hidden transition-all duration-300">
				<div class="h-full overflow-y-auto custom-scrollbar p-4 md:p-6">
					<!-- Sidebar Content -->
					<div class="space-y-6">
						<div>
							<h3 class="sidebar-subtitle text-xs md:text-sm font-semibold mb-3 transition-colors duration-300">Navigation</h3>
							<ul class="space-y-2">
								<li>
									<a href="#home" class="sidebar-link block px-3 md:px-4 py-2 rounded-lg transition-all text-sm">Home</a>
								</li>
								<li>
									<a href="#projects" class="sidebar-link block px-3 md:px-4 py-2 rounded-lg transition-all text-sm">Projects</a>
								</li>
								<li>
									<a href="#contact" class="sidebar-link block px-3 md:px-4 py-2 rounded-lg transition-all text-sm">Contact</a>
								</li>
							</ul>
						</div>

						<div class="sidebar-divider"></div>

						<div>
							<h3 class="sidebar-subtitle text-xs md:text-sm font-semibold mb-3 transition-colors duration-300">Quick Links</h3>
							<ul class="space-y-2">
								<li>
									<a href="#" class="sidebar-link block px-3 md:px-4 py-2 rounded-lg transition-all text-sm">About</a>
								</li>
								<li>
									<a href="#" class="sidebar-link block px-3 md:px-4 py-2 rounded-lg transition-all text-sm">Blog</a>
								</li>
								<li>
									<a href="#" class="sidebar-link block px-3 md:px-4 py-2 rounded-lg transition-all text-sm">Resume</a>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</aside>

		<!-- Footer -->
		<Footer />
	</body>
</html>

<style>
	body {
		background: linear-gradient(to bottom right, rgb(15, 23, 42), rgb(30, 41, 59), rgb(15, 23, 42));
	}
	
	.light-mode body {
		background: linear-gradient(to bottom right, rgb(245, 245, 245), rgb(250, 250, 250), rgb(245, 245, 245));
	}
	
	.content-container {
		background: rgba(2, 6, 23, 0.5);
		border: 1px solid rgba(var(--border-primary), 0.5);
	}
	
	.light-mode .content-container {
		background: rgb(250, 250, 250);
		border: 1px solid rgb(var(--border-primary));
	}

	/* Sidebar */
	.sidebar-width {
		width: 0;
		opacity: 0;
		pointer-events: none;
	}

	.sidebar-width.open {
		width: auto;
		min-width: 180px;
		max-width: 240px;
		opacity: 1;
		pointer-events: auto;
	}

	@media (min-width: 768px) {
		.sidebar-width.open {
			width: 320px;
			min-width: 320px;
			max-width: 320px;
		}
	}

	#main-content {
		margin-right: 0;
		transition: margin-right 0.3s ease;
	}

	#main-content.sidebar-open {
		margin-right: 180px;
	}

	@media (min-width: 768px) {
		#main-content.sidebar-open {
			margin-right: 320px;
		}
	}

	.sidebar-content {
		background: rgba(2, 6, 23, 0.5);
		border: 1px solid rgba(var(--border-primary), 0.5);
	}

	.light-mode .sidebar-content {
		background: rgb(250, 250, 250);
		border: 1px solid rgb(var(--border-primary));
	}

	.sidebar-title {
		color: rgb(var(--text-primary));
	}

	.sidebar-subtitle {
		color: rgb(var(--text-tertiary));
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.sidebar-link {
		color: rgb(var(--text-secondary));
	}

	.sidebar-link:hover {
		color: rgb(var(--text-primary));
		background: rgba(var(--bg-tertiary), 0.3);
	}

	.sidebar-divider {
		border-top: 1px solid rgba(var(--border-primary), 0.5);
	}
</style>

<script>
	// Sidebar toggle functionality
	function toggleSidebar() {
		const sidebar = document.getElementById('right-sidebar');
		const mainContent = document.getElementById('main-content');
		
		sidebar?.classList.toggle('open');
		mainContent?.classList.toggle('sidebar-open');
	}

	function closeSidebar() {
		const sidebar = document.getElementById('right-sidebar');
		const mainContent = document.getElementById('main-content');
		
		sidebar?.classList.remove('open');
		mainContent?.classList.remove('sidebar-open');
	}

	// Initialize sidebar functionality
	document.addEventListener('DOMContentLoaded', () => {
		// Close sidebar when clicking a link
		const sidebarLinks = document.querySelectorAll('#right-sidebar a');
		sidebarLinks?.forEach(link => {
			link.addEventListener('click', closeSidebar);
		});
	});

	// Export toggle function for navbar
	(window as any).toggleSidebar = toggleSidebar;
</script>
