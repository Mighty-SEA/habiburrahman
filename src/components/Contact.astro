---
// About/Profile Section
const base = import.meta.env.BASE_URL;
---

<section id="about" class="min-h-screen px-6 md:px-12 py-20 flex items-center">
  <div class="max-w-4xl mx-auto w-full">
    <h2 class="section-title text-4xl md:text-5xl font-bold mb-12 text-center transition-colors duration-300">
      Tentang Saya
    </h2>
    
    <div class="about-content space-y-8">
      <!-- Main Description -->
      <div class="profile-description space-y-4 transition-colors duration-300 text-center">
        <p>
          Saya menikmati proses membangun aplikasi web dan mobile, terutama saat menghadapi tantangan baru yang selalu memberi ruang untuk belajar. Setiap project punya cerita dan masalahnya sendiri—dan di situlah bagian menariknya.
        </p>
        <p>
          Saat ini fokus menggunakan Laravel, Vue.js, dan Flutter. Sesekali bereksperimen dengan Go dan Python, serta mulai mendalami machine learning—khususnya teknik clustering untuk analisis data.
        </p>
        <p>
          Menurut saya, program bukan hanya dibuat tapi harus benar-benar digunakan. Aplikasi yang bagus adalah yang bisa solve real problems dan adopted oleh user.
        </p>
      </div>

      <!-- Contact Cards -->
      <div class="contact-cards-grid">
        <div class="contact-card-container">
          <button class="contact-card" data-contact-type="email" data-contact-value="hibban.habiburrahman.sea@gmail.com" data-contact-link="mailto:hibban.habiburrahman.sea@gmail.com">
            <div class="flex items-center gap-3">
              <div class="contact-icon">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="contact-label">Email</p>
                <p class="contact-value">hibban.habiburrahman.sea@gmail.com</p>
              </div>
            </div>
          </button>
          <div class="contact-dropdown" id="email-dropdown">
            <button class="dropdown-item" data-action="copy">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              <span>Copy Email</span>
            </button>
            <button class="dropdown-item" data-action="open">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              <span>Open Email App</span>
            </button>
          </div>
        </div>

        <div class="contact-card-container">
          <button class="contact-card" data-contact-type="whatsapp" data-contact-value="+6285945462453" data-contact-link="https://wa.me/6285945462453">
            <div class="flex items-center gap-3">
              <div class="contact-icon">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="contact-label">WhatsApp</p>
                <p class="contact-value">+62 859-4546-2453</p>
              </div>
            </div>
          </button>
          <div class="contact-dropdown" id="whatsapp-dropdown">
            <button class="dropdown-item" data-action="copy">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              <span>Copy Number</span>
            </button>
            <button class="dropdown-item" data-action="open">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              <span>Open WhatsApp</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Download CV Card -->
      <div class="cv-card-wrapper">
        <a href={`${base}/cv.pdf`} download class="cv-card">
          <div class="flex items-center justify-center gap-3">
            <div class="contact-icon">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <span class="cv-text">Download CV</span>
          </div>
        </a>
      </div>

      <!-- Social Links -->
      <div class="flex gap-4 justify-center pt-4">
        <a href="https://github.com/Mighty-SEA" target="_blank" class="social-link" aria-label="GitHub">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="https://linkedin.com/in/yourusername" target="_blank" class="social-link" aria-label="LinkedIn">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .section-title {
    color: rgb(var(--text-primary));
  }

  .about-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .profile-description {
    color: rgb(var(--text-secondary));
    line-height: 1.9;
    font-size: 1.0625rem;
  }

  .profile-description p {
    margin-bottom: 1.5rem;
  }

  .profile-description p:last-child {
    margin-bottom: 0;
  }

  .contact-cards-grid {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  @media (min-width: 640px) {
    .contact-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .contact-card-container {
    position: relative;
  }

  .contact-card {
    display: block;
    width: 100%;
    padding: 1rem;
    border-radius: 12px;
    background: rgba(var(--bg-secondary), 0.5);
    border: 1px solid rgba(var(--border-primary), 0.5);
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    cursor: pointer;
    text-align: left;
  }

  .contact-card:hover {
    background: rgba(var(--bg-tertiary), 0.6);
    border-color: rgba(96, 165, 250, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(96, 165, 250, 0.15);
  }

  .light-mode .contact-card:hover {
    border-color: rgba(37, 99, 235, 0.5);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }

  .contact-card.active {
    border-color: rgba(96, 165, 250, 0.7);
    background: rgba(var(--bg-tertiary), 0.7);
  }

  .light-mode .contact-card.active {
    border-color: rgba(37, 99, 235, 0.7);
  }

  .contact-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    right: 0;
    background: rgba(var(--bg-secondary), 0.98);
    border: 1px solid rgba(var(--border-primary), 0.5);
    border-radius: 12px;
    padding: 0.5rem;
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    z-index: 10;
  }

  .contact-dropdown.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 8px;
    background: transparent;
    border: none;
    color: rgb(var(--text-secondary));
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 0.875rem;
  }

  .dropdown-item:hover {
    background: rgba(96, 165, 250, 0.1);
    color: rgb(96, 165, 250);
  }

  .light-mode .dropdown-item:hover {
    background: rgba(37, 99, 235, 0.1);
    color: rgb(37, 99, 235);
  }

  .dropdown-item svg {
    flex-shrink: 0;
  }

  .contact-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(96, 165, 250, 0.1);
    color: rgb(96, 165, 250);
    flex-shrink: 0;
  }

  .light-mode .contact-icon {
    background: rgba(37, 99, 235, 0.1);
    color: rgb(37, 99, 235);
  }

  .contact-label {
    font-size: 0.75rem;
    color: rgb(var(--text-tertiary));
    margin-bottom: 0.125rem;
    font-weight: 500;
  }

  .contact-value {
    font-size: 0.875rem;
    color: rgb(var(--text-primary));
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* CV Card */
  .cv-card-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }

  .cv-card {
    display: inline-flex;
    padding: 1rem 2rem;
    border-radius: 12px;
    background: rgba(var(--bg-secondary), 0.5);
    border: 1px solid rgba(var(--border-primary), 0.5);
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    text-decoration: none;
  }

  .cv-card:hover {
    background: rgba(96, 165, 250, 0.1);
    border-color: rgba(96, 165, 250, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(96, 165, 250, 0.15);
  }

  .light-mode .cv-card:hover {
    background: rgba(37, 99, 235, 0.1);
    border-color: rgba(37, 99, 235, 0.5);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }

  .cv-text {
    font-size: 1rem;
    color: rgb(var(--text-primary));
    font-weight: 600;
  }

  .social-link {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(var(--bg-tertiary), 0.5);
    color: rgb(var(--text-secondary));
    border: 1px solid rgba(var(--border-primary), 0.5);
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background: rgba(96, 165, 250, 0.2);
    color: rgb(96, 165, 250);
    border-color: rgba(96, 165, 250, 0.5);
    transform: translateY(-3px);
  }

  .light-mode .social-link:hover {
    background: rgba(37, 99, 235, 0.1);
    color: rgb(37, 99, 235);
    border-color: rgba(37, 99, 235, 0.5);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const contactCards = document.querySelectorAll('.contact-card');
    let activeDropdown: HTMLElement | null = null;

    // Toggle dropdown
    contactCards.forEach((card) => {
      card.addEventListener('click', (e) => {
        e.stopPropagation();
        const container = card.closest('.contact-card-container');
        const dropdown = container?.querySelector('.contact-dropdown') as HTMLElement;
        
        if (!dropdown) return;

        // Close other dropdowns
        if (activeDropdown && activeDropdown !== dropdown) {
          activeDropdown.classList.remove('show');
          activeDropdown.previousElementSibling?.classList.remove('active');
        }

        // Toggle current dropdown
        const isShowing = dropdown.classList.contains('show');
        dropdown.classList.toggle('show');
        card.classList.toggle('active');

        activeDropdown = isShowing ? null : dropdown;
      });
    });

    // Handle dropdown actions
    document.querySelectorAll('.dropdown-item').forEach((item) => {
      item.addEventListener('click', async (e) => {
        e.stopPropagation();
        const action = (item as HTMLElement).dataset.action;
        const container = item.closest('.contact-card-container');
        const card = container?.querySelector('.contact-card') as HTMLElement;
        const contactValue = card?.dataset.contactValue;
        const contactLink = card?.dataset.contactLink;
        const dropdown = container?.querySelector('.contact-dropdown') as HTMLElement;

        if (action === 'copy' && contactValue) {
          try {
            await navigator.clipboard.writeText(contactValue);
            
            // Show copied feedback
            const originalText = item.querySelector('span')?.textContent;
            const span = item.querySelector('span');
            if (span) {
              span.textContent = 'Copied!';
              setTimeout(() => {
                span.textContent = originalText || '';
              }, 2000);
            }
          } catch (err) {
            console.error('Failed to copy:', err);
          }
        } else if (action === 'open' && contactLink) {
          window.open(contactLink, '_blank');
        }

        // Close dropdown
        dropdown?.classList.remove('show');
        card?.classList.remove('active');
        activeDropdown = null;
      });
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', () => {
      if (activeDropdown) {
        activeDropdown.classList.remove('show');
        activeDropdown.previousElementSibling?.classList.remove('active');
        activeDropdown = null;
      }
    });
  });
</script>
