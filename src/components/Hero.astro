---
// Hero Section untuk portfolio
---

<section id="home" class="min-h-screen flex items-center justify-center px-6 md:px-12 -mt-16">
  <div class="max-w-5xl mx-auto text-center">
    <h1 class="hero-title text-5xl md:text-7xl font-bold mb-6 transition-colors duration-300">
      Halo, Saya 
    </h1>
    <div class="typing-wrapper mb-6">
      <span class="typing-text">
        <span id="typed-text" class="bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent"></span>
        <span class="cursor">|</span>
      </span>
    </div>
    <p class="hero-subtitle text-xl md:text-2xl mb-8 transition-colors duration-300">
      Bikin aplikasi yang beneran dipake, bukan cuma jadi portfolio
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="#projects" class="px-8 py-3 bg-blue-500 hover:bg-blue-600 text-white rounded-lg transition-colors">
        Lihat Proyek
      </a>
      <a href="#about" class="hero-btn px-8 py-3 rounded-lg transition-all">
        Tentang Saya
      </a>
    </div>
  </div>
</section>

<style>
  .hero-title {
    color: rgb(var(--text-primary));
  }
  
  .hero-subtitle {
    color: rgb(var(--text-secondary));
  }
  
  .hero-btn {
    border: 1px solid rgb(var(--border-secondary));
    color: rgb(var(--text-primary));
  }
  
  .hero-btn:hover {
    border-color: rgb(var(--text-tertiary));
  }

  .typing-wrapper {
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .typing-text {
    font-size: clamp(2rem, 10vw, 4rem);
    font-weight: bold;
    display: inline-block;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .typing-text {
      font-size: 5.5rem;
      white-space: nowrap;
    }
    .typing-wrapper {
      min-height: 120px;
    }
  }

  @media (min-width: 1024px) {
    .typing-text {
      font-size: 6rem;
    }
    .typing-wrapper {
      min-height: 140px;
    }
  }

  .cursor {
    display: inline-block;
    margin-left: -0.15em;
    background: linear-gradient(to right, #60a5fa, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: opacity 0.1s ease;
  }

  .cursor.blinking {
    animation: blink 0.7s infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
</style>

<script>
  const texts = ['Web Developer', 'Software Engineer', 'Hibban Habiburrahman'];
  let textIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let typingSpeed = 100;

  function type() {
    const typedTextElement = document.getElementById('typed-text');
    const cursorElement = document.querySelector('.cursor');
    if (!typedTextElement || !cursorElement) return;

    const currentText = texts[textIndex];

    if (isDeleting) {
      // Hapus karakter
      typedTextElement.textContent = currentText.substring(0, charIndex - 1);
      charIndex--;
      typingSpeed = 50; // Lebih cepat saat menghapus
      cursorElement.classList.remove('blinking');
    } else {
      // Ketik karakter
      typedTextElement.textContent = currentText.substring(0, charIndex + 1);
      charIndex++;
      typingSpeed = 100; // Kecepatan mengetik yang smooth
      cursorElement.classList.remove('blinking');
    }

    // Jika selesai mengetik
    if (!isDeleting && charIndex === currentText.length) {
      typingSpeed = 2000; // Tunggu 2 detik
      isDeleting = true;
      cursorElement.classList.add('blinking');
    }
    // Jika selesai menghapus
    else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      textIndex = (textIndex + 1) % texts.length;
      typingSpeed = 300; // Pause sebentar sebelum mulai ketik lagi
    }

    setTimeout(type, typingSpeed);
  }

  // Mulai animasi saat halaman load
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(type, 500); // Delay lebih pendek untuk mulai lebih cepat
  });
</script>
