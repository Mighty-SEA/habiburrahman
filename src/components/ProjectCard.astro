---
const { project, base } = Astro.props;
---

<div class={`project-card scroll-animate backdrop-blur-sm rounded-xl overflow-hidden hover:border-blue-500/50 transition-all hover:transform hover:scale-[1.02] ${project.featured ? 'featured-card' : ''}`}>
  {project.image && (
    <div class="project-image">
      <img src={base + project.image} alt={project.title} loading="lazy" />
    </div>
  )}
  <div class="project-content p-6 flex flex-col h-full">
    <h3 class="card-title text-xl md:text-2xl font-semibold mb-3 transition-colors duration-300">{project.title}</h3>
    <p class="card-desc mb-4 flex-grow transition-colors duration-300">{project.description}</p>
    <div class="flex flex-wrap gap-2 mb-4">
      {project.tech.map((tech) => (
        <span class="tech-badge text-xs md:text-sm rounded-full px-3 py-1 transition-colors duration-300">
          {tech}
        </span>
      ))}
    </div>
    {project.gallery ? (
      <button 
        class="card-link transition-colors inline-flex items-center gap-1"
        data-project-id={project.id}
        onclick="window.showProjectDetail(this)"
      >
        Lihat Detail 
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    ) : (
      <a href={project.link} class="card-link transition-colors inline-flex items-center gap-1">
        Lihat Detail 
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    )}
  </div>
</div>

<style>
  .project-card {
    background: rgba(var(--bg-secondary), 0.5);
    border: 1px solid rgba(var(--border-primary), 0.5);
    display: flex;
    flex-direction: column;
  }

  .project-image {
    width: 100%;
    height: 280px;
    overflow: hidden;
    background: rgba(var(--bg-tertiary), 0.3);
  }

  @media (min-width: 768px) {
    .project-image {
      height: 320px;
    }
  }

  @media (min-width: 1024px) {
    .project-image {
      height: 350px;
    }
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-content {
    flex: 1;
  }
  
  .card-title {
    color: rgb(var(--text-primary));
  }
  
  .card-desc {
    color: rgb(var(--text-secondary));
    font-size: 0.95rem;
    line-height: 1.6;
  }
  
  .tech-badge {
    background: rgba(var(--bg-tertiary), 0.5);
    color: rgb(96, 165, 250);
    border: 1px solid rgba(96, 165, 250, 0.3);
  }
  
  .light-mode .tech-badge {
    color: rgb(37, 99, 235);
    border-color: rgba(37, 99, 235, 0.3);
  }
  
  .card-link {
    color: rgb(96, 165, 250);
    font-weight: 500;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }
  
  .card-link:hover {
    color: rgb(147, 197, 253);
  }
  
  .light-mode .card-link {
    color: rgb(37, 99, 235);
  }
  
  .light-mode .card-link:hover {
    color: rgb(29, 78, 216);
  }
</style>
