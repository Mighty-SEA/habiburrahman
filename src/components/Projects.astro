---
import projectsData from '../data/projects.json';
import ProjectCard from './ProjectCard.astro';
import ProjectDetail from './ProjectDetail.astro';

const base = import.meta.env.BASE_URL;
---

<section id="projects" class="min-h-screen px-6 md:px-12 py-20">
  <div class="max-w-7xl mx-auto">
    <h2 class="section-title text-4xl md:text-5xl font-bold mb-12 text-center transition-colors duration-300 scroll-animate">
      Proyek Saya
    </h2>
    
    <!-- Project Grid View -->
    <div id="projects-grid" class="bento-grid gap-4 md:gap-6">
      {projectsData.map((project, index) => (
        <ProjectCard project={project} base={base} />
      ))}
    </div>

    <!-- Project Detail View -->
    <ProjectDetail />
  </div>
</section>

<script>
  import '../scripts/projectDetail.js';
  import '../scripts/scrollAnimation.js';
</script>

<style>
  .section-title {
    color: rgb(var(--text-primary));
  }
  
  /* Bento Grid Layout */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(280px, auto);
    grid-auto-flow: dense;
  }

  .bento-grid > :global(.project-card) {
    grid-column: span 12;
  }

  @media (min-width: 768px) {
    .bento-grid > :global(.project-card:nth-child(1)) {
      grid-column: span 8;
      grid-row: span 2;
    }

    .bento-grid > :global(.project-card:nth-child(1) .project-image) {
      height: 400px;
    }

    .bento-grid > :global(.project-card:nth-child(2)) {
      grid-column: span 4;
    }

    .bento-grid > :global(.project-card:nth-child(3)) {
      grid-column: span 4;
    }

    .bento-grid > :global(.project-card:nth-child(4)) {
      grid-column: span 4;
    }

    .bento-grid > :global(.project-card:nth-child(5)) {
      grid-column: span 4;
    }

    .bento-grid > :global(.project-card:nth-child(6)) {
      grid-column: span 4;
    }
  }

  @media (min-width: 1024px) {
    .bento-grid {
      grid-auto-rows: minmax(300px, auto);
    }

    .bento-grid > :global(.project-card:nth-child(1) .project-image) {
      height: 450px;
    }
  }
</style>
